# Copy to .env.local and fill from your Supabase project (Settings → API).
# Restart `npm run dev` after editing.

# Public — safe in the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Secret — used ONLY by scripts/seed-kulams.mjs. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret — Google AI Studio (Gemini) key for AI horoscope insights.
# Get a free key at https://aistudio.google.com/apikey (no card needed).
GEMINI_API_KEY=your-gemini-api-key
# Optional model override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash-lite
